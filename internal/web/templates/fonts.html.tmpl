{{define "fonts.html.tmpl"}}<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Typeface preview — Motson index</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚽</text></svg>">
  <link rel="stylesheet" href="/static/fonts.css?v={{.AssetVersion}}">
  <style>
    :root {
      --bg: #11151a; --surface: #1f2730; --surface-2: #181e26;
      --border: #2a333d; --ink: #e8e6e3; --muted: #8d97a3; --accent: #ffd23f;
    }
    * { box-sizing: border-box; }
    html { background: var(--bg); }
    body { margin: 0; background: var(--bg); color: var(--ink); font-family: Inter, -apple-system, system-ui, sans-serif; }
    a { color: var(--accent); }
    header.intro { padding: 2.5rem clamp(1rem, 4vw, 3rem) 1.5rem; border-bottom: 1px solid var(--border); }
    header.intro h1 { margin: 0; color: #fff; font-family: "Bebas Neue", Inter, sans-serif; font-weight: 400; font-size: clamp(2.2rem, 5vw, 3.4rem); letter-spacing: .06em; }
    header.intro p { margin: .6rem 0 0; max-width: 70ch; color: var(--muted); line-height: 1.5; }
    header.intro .ref { margin-top: .9rem; font-size: .9rem; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(440px, 1fr)); gap: 1.5rem; padding: clamp(1rem, 4vw, 2.5rem); }
    figure { margin: 0; display: flex; flex-direction: column; background: var(--surface-2); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    figcaption { padding: .85rem 1rem; border-bottom: 1px solid var(--border); }
    figcaption a { font-family: "Bebas Neue", Inter, sans-serif; font-size: 1.45rem; letter-spacing: .04em; text-decoration: none; }
    figcaption a:hover { text-decoration: underline; }
    figcaption .fnote { display: block; margin-top: .15rem; color: var(--muted); font-size: .82rem; }
    iframe { width: 100%; height: 820px; border: 0; background: var(--bg); }
    @media (max-width: 520px) { .grid { grid-template-columns: 1fr; } iframe { height: 640px; } }
  </style>
</head>
<body>
  <header class="intro">
    <h1>Typeface preview</h1>
    <p>The World Cup 2026 index rendered with ten alternatives to Inter for the body and score type. Each frame is the live page — click a name to open it full-size. The Bebas Neue title is unchanged throughout; only the data face varies.</p>
    <p class="ref">Reference: <a href="/">the current build (Inter)</a>.</p>
  </header>
  <div class="grid">
    {{range .Fonts}}
    <figure>
      <figcaption>
        <a href="/?font={{.Slug}}" target="_blank" rel="noopener">{{.Name}}</a>
        <span class="fnote">{{.Note}}</span>
      </figcaption>
      <iframe src="/?font={{.Slug}}" title="Motson index in {{.Name}}" loading="lazy"></iframe>
    </figure>
    {{end}}
  </div>
</body>
</html>{{end}}
