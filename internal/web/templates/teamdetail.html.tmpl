<!DOCTYPE html>
<html lang="en">
{{template "head" .}}
<body>
  {{template "siteheader" .}}
  <div class="layout">
    {{template "sidebar" .Nav}}
    <main class="content" id="main" tabindex="-1">
      <p class="intro">
        {{.TeamName}}'s group, results and fixtures, updated every 10 minutes.
        <a href="/">All fixtures</a>.
      </p>
    <h2>{{if .Flag}}{{.Flag}} {{end}}{{.TeamName}}</h2>
    {{if .Standings}}
    <h3>{{if .GroupURL}}<a href="{{.GroupURL}}">{{.GroupName}}</a>{{else}}{{.GroupName}}{{end}}</h3>
{{template "standingsTable" .Standings}}
    {{end}}
    <table>
      <thead>
        <tr><th>Kick-off</th><th colspan="3" class="match">Match</th><th>Stage</th>{{if .HasVenues}}<th>Venue</th>{{end}}</tr>
      </thead>
      <tbody>
        {{range .Matches}}
        <tr class="fixture">
          <td><time datetime="{{.KickoffUTC}}">{{.KickoffUTC}}</time></td>
          {{template "matchCells" .}}
          <td>{{if .StageURL}}<a href="{{.StageURL}}">{{.StageLabel}}</a>{{else}}{{.StageLabel}}{{end}}</td>
          {{if $.HasVenues}}<td>{{.Venue}}</td>{{end}}
        </tr>
        {{end}}
      </tbody>
    </table>
    <h3>Other teams</h3>
    <p class="teams">
      {{range $i, $t := .OtherTeams}}{{if $i}} · {{end}}<a href="{{$t.URL}}">{{if $t.Flag}}{{$t.Flag}} {{end}}{{$t.Name}}</a>{{end}}
    </p>
{{template "footer" .}}
</body>
</html>
