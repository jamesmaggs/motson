<!DOCTYPE html>
<html lang="en">
{{template "head" .}}
<body>
  {{template "siteheader" .}}
  <div class="layout">
    {{template "sidebar" .Nav}}
    <main class="content" id="main" tabindex="-1">
      <div class="group-cols">
        <aside class="standings-col" aria-label="{{.TeamName}} group standings">
          <div class="standings-card">
            <h2 class="standings-title">{{if .Flag}}{{.Flag}} {{end}}{{.TeamName}}</h2>
            {{if .GroupName}}<p class="standings-sub">{{if .GroupURL}}<a href="{{.GroupURL}}">{{.GroupName}}</a>{{else}}{{.GroupName}}{{end}}</p>{{end}}
            {{if .Standings}}{{template "standingsTable" .Standings}}{{end}}
          </div>
        </aside>
        <section class="match-col" aria-label="{{.TeamName}} matches">
          <div class="cards">
            {{range .Matches}}{{template "matchCard" .}}{{end}}
          </div>
        </section>
      </div>
{{template "footer" .}}
</body>
</html>
