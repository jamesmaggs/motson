<!DOCTYPE html>
<html lang="en">
{{template "head" .}}
<body>
  <main class="container">
    <header>
      <h1>⚽ World Cup 2026</h1>
      <p>
        {{.GroupName}} table, results and fixtures, updated hourly.
        <a href="/groups">All groups</a> · <a href="/">All fixtures</a>.
      </p>
    </header>
    <h2>{{.GroupName}}</h2>
{{template "standingsTable" .Standings}}
    <table class="fixtures">
      <colgroup><col class="c-kick"><col class="c-side"><col class="c-score"><col class="c-side">{{if $.HasVenues}}<col>{{end}}</colgroup>
      <thead>
        <tr><th>Kick-off</th><th colspan="3" class="match">Match</th>{{if .HasVenues}}<th>Venue</th>{{end}}</tr>
      </thead>
      <tbody>
        {{range .Matches}}
        <tr class="fixture">
          <td><time datetime="{{.KickoffUTC}}">{{.KickoffUTC}}</time></td>
          {{template "matchCells" .}}
          {{if $.HasVenues}}<td>{{.Venue}}</td>{{end}}
        </tr>
        {{end}}
      </tbody>
    </table>
{{template "footer" .}}
</body>
</html>
