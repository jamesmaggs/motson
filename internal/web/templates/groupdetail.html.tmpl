<!DOCTYPE html>
<html lang="en">
{{template "head" .}}
<body>
  {{template "siteheader" .}}
  <div class="layout">
    {{template "sidebar" .Nav}}
    <main class="content" id="main" tabindex="-1">
      <p class="intro">
        {{.GroupName}} table, results and fixtures, updated every 10 minutes.
        <a href="/">All fixtures</a>.
      </p>
      <div class="group-cols">
        <aside class="standings-col" aria-label="{{.GroupName}} table">
          <h2 class="col-head">Standings</h2>
          <div class="standings-card">
{{template "standingsTable" .Standings}}
          </div>
        </aside>
        <section class="match-col" aria-label="{{.GroupName}} matches">
          <h2 class="col-head">{{.GroupName}}</h2>
          <div class="cards">
            {{range .Matches}}{{template "matchCard" .}}{{end}}
          </div>
        </section>
      </div>
{{template "footer" .}}
</body>
</html>
