{{define "error.html.tmpl"}}<!DOCTYPE html>
<html lang="en">
{{template "head" .}}
<body>
  {{template "siteheader" .}}
  <main class="content error-page" id="main" tabindex="-1">
    <p class="error-status">{{.Status}}</p>
    <h2 class="error-title">{{.Title}}</h2>
    <p class="error-message">{{.Message}}</p>
    <p><a class="error-home" href="/">← Back to all fixtures</a></p>
  </main>
</body>
</html>{{end}}
