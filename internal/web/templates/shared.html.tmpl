{{define "head"}}
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Motson — World Cup 2026 fixtures</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚽</text></svg>">
  <link rel="stylesheet" href="/static/pico.min.css?v={{.AssetVersion}}">
  <link rel="stylesheet" href="/static/fonts.css?v={{.AssetVersion}}">
  <link rel="alternate" type="text/calendar" title="World Cup 2026 calendar" href="/calendar.ics">
  <style>
    /* Floodlit scoreboard: dark night-match chrome, amber scores,
       Bebas Neue title over Inter data. */
    html { background: #11151a; }
    body { background: #11151a; color: #e8e6e3; font-family: Inter, -apple-system, system-ui, sans-serif; min-height: 100vh; }
    main h1, main h2, main p, main th, main td, footer p { color: #e8e6e3; }
    h1 { color: #fff; font-family: "Bebas Neue", Inter, sans-serif; font-weight: 400; font-size: 3rem; letter-spacing: .06em; }
    h2 { color: #fff; font-family: "Bebas Neue", Inter, sans-serif; font-weight: 400; font-size: 1.6rem; letter-spacing: .06em; margin: 2.5rem 0 0; }
    table { --pico-background-color: transparent; font-size: .85em; margin-top: 2.5rem; margin-bottom: 2.5rem; }
    h2 + table { margin-top: .75rem; }
    h3 { color: #8d97a3; font-family: "Bebas Neue", Inter, sans-serif; font-weight: 400; font-size: 1.1rem; letter-spacing: .08em; margin: 2rem 0 0; }
    h3 + table { margin-top: .75rem; }
    h3 a { color: inherit; text-decoration: none; }
    h3 a:hover { text-decoration: underline; }
    ul.teams { list-style: none; padding: 0; margin: 2.5rem 0; columns: 3; }
    ul.teams li { margin: .4rem 0; }
    ul.teams a, p.teams a { color: inherit; text-decoration: none; }
    ul.teams a:hover, p.teams a:hover { text-decoration: underline; }
    p.teams { line-height: 2; }
    table.fixtures { table-layout: fixed; }
    col.c-kick { width: 24%; }
    col.c-side { width: 31%; }
    col.c-score { width: 14%; }
    tbody td { font-weight: 300; }
    thead th { color: #8d97a3; border-bottom: 2px solid #2a313a; text-transform: uppercase; font-size: .8em; letter-spacing: .08em; }
    thead th.match { text-align: center; }
    tbody td { border-color: #232a32; }
    tbody tr:hover { background: #171c22; }
    a { color: #ffd23f; }
    tbody td a, h2 a { color: inherit; text-decoration: none; }
    tbody td a:hover, h2 a:hover { text-decoration: underline; }
    .fixture td:first-child { white-space: nowrap; }
    td.home { text-align: right; }
    td.score { text-align: center; font-weight: 700; font-size: 1.15em; white-space: nowrap; color: #ffd23f; font-variant-numeric: tabular-nums; text-shadow: 0 0 12px rgba(255, 210, 63, .35); }
    td.away { text-align: left; }
    .state { color: #79838e; font-weight: 400; text-shadow: none; }
    td.score .state { font-size: .7em; }
    footer p { font-size: .75em; }

    /* Match cards (index) */
    .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); grid-auto-rows: 1fr; gap: 1rem; margin: 2.5rem 0; }
    .card { background: #1f2730; border: 1px solid #2a333d; border-radius: 16px; padding: 1.1rem 1.2rem 1.3rem; box-shadow: none; margin: 0; }
    .card-top { display: flex; justify-content: space-between; align-items: flex-start; gap: .5rem; margin-bottom: 1rem; }
    .meta { display: flex; flex-direction: column; gap: .25rem; }
    .stage { text-transform: uppercase; font-size: .62rem; letter-spacing: .1em; color: #8d97a3; }
    .kickoff { color: #e8e6e3; font-size: .72rem; }
    .group { font-size: .72rem; padding: .2rem .65rem; border-radius: 999px; background: rgba(47,191,113,.16); color: #5fd99a; white-space: nowrap; text-decoration: none; }
    .group:hover { background: rgba(47,191,113,.28); }
    .scoreline { display: grid; grid-template-columns: 1fr auto 1fr; align-items: start; gap: .5rem; }
    .side { text-align: center; }
    .side .flag { font-size: 2.8rem; line-height: 1; }
    .name { display: block; margin-top: .5rem; font-size: .9rem; font-weight: 300; }
    .name a { color: inherit; text-decoration: none; }
    .name a:hover { text-decoration: underline; }
    .score { font-size: 2rem; font-weight: 700; color: #ffd23f; font-variant-numeric: tabular-nums; white-space: nowrap; padding-top: .5rem; }
    .score .sep { margin: 0 .3rem; color: #79838e; font-weight: 400; }
    .vs { font-size: 1.1rem; color: #79838e; padding-top: .9rem; }
    .pens { display: block; font-size: .68rem; font-weight: 400; color: #79838e; margin-top: .2rem; }
    .venue { text-align: center; color: #79838e; font-size: .72rem; margin-top: .9rem; }
    .status { text-align: center; color: #79838e; font-size: .72rem; margin-top: .9rem; }

    /* Full-width site header above a two-column layout. The mascot is
       sized in rem so it scales with the header's type, and sits flush
       against the bottom border on the right. */
    .site-header { border-bottom: 1px solid #232a32; }
    .site-header-inner { display: flex; justify-content: space-between; align-items: flex-end; max-width: 1180px; margin: 0 auto; padding: 1.2rem 1.5rem 0; }
    .site-header h1 { margin: 0 0 1.2rem; }
    .site-header .mascot { height: 6rem; width: auto; display: block; }
    .layout { display: flex; gap: 2rem; max-width: 1180px; margin: 0 auto; padding: 1.5rem; align-items: flex-start; }
    .content { flex: 1 1 auto; min-width: 0; }
    .content .intro { margin-top: 0; color: #8d97a3; }
    /* The sidebar scrolls with the page so the full team list is reachable. */
    .sidebar { flex: 0 0 200px; }
    .sidebar-nav .nav-heading { text-transform: uppercase; font-size: .66rem; letter-spacing: .1em; color: #8d97a3; margin: 1.4rem 0 .5rem; }
    .sidebar-nav ul { list-style: none; padding: 0; margin: 0; }
    .sidebar-nav li { margin: .1rem 0; }
    .sidebar-nav a { display: flex; align-items: center; gap: .5rem; color: #e8e6e3; text-decoration: none; font-size: .85rem; font-weight: 300; padding: .3rem .55rem; border-radius: 8px; }
    .sidebar-nav a:hover { background: #1f2730; }
    .sidebar-nav .nav-groups a { font-weight: 400; }
    .sidebar .flag { font-size: 1.15rem; line-height: 1; }
    @media (max-width: 720px) {
      .layout { flex-direction: column; padding: 1rem; }
      .sidebar { position: static; flex-basis: auto; width: 100%; }
      .sidebar-nav .nav-teams { columns: 2; }
    }
  </style>
</head>
{{end}}

{{define "siteheader"}}
  <header class="site-header">
    <div class="site-header-inner">
      <h1>⚽ World Cup 2026</h1>
      <img class="mascot" src="/static/motson.png?v={{.AssetVersion}}" alt="John Motson">
    </div>
  </header>
{{end}}

{{define "sidebar"}}
    <aside class="sidebar">
      <nav class="sidebar-nav">
        <p class="nav-heading">Groups</p>
        <ul class="nav-groups">
          {{range .Groups}}<li><a href="{{.URL}}">{{.Name}}</a></li>{{end}}
        </ul>
        <p class="nav-heading">Teams</p>
        <ul class="nav-teams">
          {{range .Teams}}<li><a href="{{.URL}}">{{if .Flag}}<span class="flag">{{.Flag}}</span>{{end}}{{.Name}}</a></li>{{end}}
        </ul>
      </nav>
    </aside>
{{end}}

{{define "matchCells"}}
          <td class="home">{{if .HomeURL}}<a href="{{.HomeURL}}">{{.HomeTeam}}</a>{{else}}{{.HomeTeam}}{{end}}{{if .HomeFlag}} {{.HomeFlag}}{{end}}</td>
          <td class="score">
            {{if .Score}}{{.Score}}{{else}}<span class="state">vs</span>{{end}}
            {{if .Pens}}<br><small class="state">{{.Pens}}</small>{{end}}
            {{if .StatusLabel}}<br><small class="state">{{.StatusLabel}}</small>{{end}}
          </td>
          <td class="away">{{if .AwayFlag}}{{.AwayFlag}} {{end}}{{if .AwayURL}}<a href="{{.AwayURL}}">{{.AwayTeam}}</a>{{else}}{{.AwayTeam}}{{end}}</td>
{{end}}

{{define "standingsTable"}}
    <table>
      <thead>
        <tr><th>Team</th><th>P</th><th>W</th><th>D</th><th>L</th><th>GF</th><th>GA</th><th>GD</th><th>Pts</th></tr>
      </thead>
      <tbody>
        {{range .}}
        <tr>
          <td>{{if .URL}}<a href="{{.URL}}">{{.Team}}</a>{{else}}{{.Team}}{{end}}</td>
          <td>{{.Played}}</td>
          <td>{{.Won}}</td>
          <td>{{.Drawn}}</td>
          <td>{{.Lost}}</td>
          <td>{{.GoalsFor}}</td>
          <td>{{.GoalsAgainst}}</td>
          <td>{{.GoalDifference}}</td>
          <td class="points">{{.Points}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
{{end}}

{{define "footer"}}
    <footer>
      <p class="state">
        Last updated
        {{if .LastSyncedUTC}}<time datetime="{{.LastSyncedUTC}}">{{.LastSyncedUTC}}</time>{{else}}never{{end}}.
        Times shown in your local timezone.
      </p>
    </footer>
    </main>
  </div>
  <script>
    for (const el of document.querySelectorAll("time[datetime]")) {
      const d = new Date(el.getAttribute("datetime"));
      if (!isNaN(d)) {
        el.textContent = d.toLocaleString(undefined, {
          weekday: "short", day: "numeric", month: "short",
          hour: "2-digit", minute: "2-digit"
        });
      }
    }
  </script>
{{end}}
