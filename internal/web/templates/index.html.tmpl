<!DOCTYPE html>
<html lang="en">
{{template "head" .}}
<body>
  {{template "siteheader" .}}
  <div class="layout">
    {{template "sidebar" .Nav}}
    <main class="content" id="main" tabindex="-1">
    {{with .Featured}}
    <section class="featured{{if .Live}} live{{end}}" aria-label="{{if .Live}}Match in progress{{else}}Next match{{end}}">
      <h2 class="featured-title">{{if .Live}}Live now{{else}}Next Match{{end}}</h2>
      {{template "matchCard" .}}
    </section>
    {{end}}
    {{if .Days}}
    {{template "matchDays" .Days}}
    {{else}}
    <p class="empty">No fixtures yet — they'll appear here as soon as the match schedule is published.</p>
    {{end}}
{{template "footer" .}}
</body>
</html>
