<!DOCTYPE html>
<html lang="en">
{{template "head" .}}
<body>
  {{template "siteheader" .}}
  <div class="layout">
    {{template "sidebar" .Nav}}
    <main class="content">
      <p class="intro">
        Fixtures and scores, updated hourly.
        <a href="webcal://{{.FeedHost}}/calendar.ics">Subscribe in your calendar</a>
        to get scores as events update.
      </p>
    <div class="cards">
      {{range .Matches}}
      <article class="card{{if .Live}} live{{end}}">
        <div class="card-top">
          <div class="meta">
            <span class="stage">{{.StageName}}</span>
            <time class="kickoff" datetime="{{.KickoffUTC}}">{{.KickoffUTC}}</time>
          </div>
          {{if .GroupName}}<a class="group" href="{{.GroupURL}}">{{.GroupName}}</a>{{end}}
        </div>
        <div class="scoreline">
          <div class="side">
            <span class="flag">{{.HomeFlag}}</span>
            <span class="name">{{if .HomeURL}}<a href="{{.HomeURL}}">{{.HomeTeam}}</a>{{else}}{{.HomeTeam}}{{end}}</span>
          </div>
          {{if .HomeGoals}}<div class="score">{{.HomeGoals}}<span class="sep">:</span>{{.AwayGoals}}{{if .Pens}}<span class="pens">{{.Pens}}</span>{{end}}</div>{{else}}<div class="vs">vs</div>{{end}}
          <div class="side">
            <span class="flag">{{.AwayFlag}}</span>
            <span class="name">{{if .AwayURL}}<a href="{{.AwayURL}}">{{.AwayTeam}}</a>{{else}}{{.AwayTeam}}{{end}}</span>
          </div>
        </div>
        {{if .Venue}}<div class="venue">{{.Venue}}</div>{{end}}
        {{if and .StatusLabel (not .Live)}}<div class="status">{{.StatusLabel}}</div>{{end}}
      </article>
      {{end}}
    </div>
{{template "footer" .}}
</body>
</html>
