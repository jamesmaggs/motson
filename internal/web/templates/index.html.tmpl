<!DOCTYPE html>
<html lang="en">
{{template "head" .}}
<body>
  <main class="container">
    <header>
      <h1>⚽ World Cup 2026</h1>
      <p>
        Fixtures and scores, updated hourly.
        <a href="webcal://{{.FeedHost}}/calendar.ics">Subscribe in your calendar</a>
        to get scores as events update, or <a href="/groups">browse by group</a>.
      </p>
    </header>
    <table>
      <thead>
        <tr><th>Kick-off</th><th colspan="3" class="match">Match</th><th>Stage</th>{{if .HasVenues}}<th>Venue</th>{{end}}</tr>
      </thead>
      <tbody>
        {{range .Matches}}
        <tr class="fixture">
          <td><time datetime="{{.KickoffUTC}}">{{.KickoffUTC}}</time></td>
          {{template "matchCells" .}}
          <td>{{if .StageURL}}<a href="{{.StageURL}}">{{.StageLabel}}</a>{{else}}{{.StageLabel}}{{end}}</td>
          {{if $.HasVenues}}<td>{{.Venue}}</td>{{end}}
        </tr>
        {{end}}
      </tbody>
    </table>
{{template "footer" .}}
</body>
</html>
